# Browser-facing variables (Next.js). Copy to `apps/web/.env.local`.
# Rebuild the web Docker image after changing these (they are baked in at build).

# Public URL of the API as seen from the **browser** (your phone/laptop).
# Same machine: http://localhost:3001
# Docker on a server: http://YOUR_SERVER_IP:3001 or https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# Dev-only: UUID of the seeded user (`npm run seed` prints this).
# Leave empty if you use `?userId=<uuid>` once (stored in localStorage) or add auth later.
NEXT_PUBLIC_DEV_USER_ID=
