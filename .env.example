# =============================================================================
# DevPlanner — environment template
# Copy to `.env` in this folder (API + worker read it). Next.js also reads
# `apps/web/.env.local` for browser vars — see `apps/web/.env.local.example`.
# =============================================================================

# -----------------------------------------------------------------------------
# Core (required for API + worker)
# -----------------------------------------------------------------------------
# Node: use production on servers; development enables API error stacks in JSON.
NODE_ENV=development

# API HTTP listen (inside container use 3001; map host port in compose if needed).
PORT=3001
# Bind address (0.0.0.0 = all interfaces — required in Docker / VPS).
HOST=0.0.0.0

# Postgres (pgvector). Default matches docker-compose `devplanner-db` on the host.
# In Docker Compose profile `app`, compose overrides this to use service `devplanner-db:5432`.
DATABASE_URL=postgresql://devplanner:devplanner@localhost:5433/devplanner

# Redis — queues (CalDAV / Google sync) and BullMQ worker. Optional for API-only;
# without Redis, sync jobs are skipped when queues cannot connect.
REDIS_URL=redis://localhost:6379

# Comma-separated browser origins allowed to call the API (CORS).
CORS_ORIGIN=http://localhost:3000

# Public URL of the web UI (same value you use for NEXTAUTH_URL in production).
# Only one line needed: WEB_APP_URL or APP_URL (API checks WEB_APP_URL first, then APP_URL).
WEB_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# One-time / dev helpers (optional)
# -----------------------------------------------------------------------------
# Email for `npm run seed` (creates dev user and areas).
SEED_USER_EMAIL=dev@localhost

# -----------------------------------------------------------------------------
# AI features (`/api/ai/*`) — optional; routes return errors if key missing
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# Optional overrides (defaults in code: gpt-4o-mini).
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_SMART_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# CalDAV (Radicale) — optional; worker pushes/pulls when CALDAV_* is set
# -----------------------------------------------------------------------------
# Collection URL with trailing slash. From API container use the compose service
# hostname, e.g. http://radicale:5232/youruser/tasks/
# CALDAV_CALENDAR_URL=http://localhost:5232/youruser/tasks/
# CALDAV_USER=youruser
# CALDAV_PASSWORD=secret

# Default area UUID for events imported from calendar (else first area by sort).
# CALDAV_IMPORT_AREA_ID=

# Worker: periodic CalDAV pull for all users (ms). 0 = disabled.
CALDAV_PULL_INTERVAL_MS=0

# -----------------------------------------------------------------------------
# Auth (Google Sign-In) + API session verification
# -----------------------------------------------------------------------------
# Same Google Cloud "Web application" OAuth client can list both redirect URIs:
#   https://yourdomain.com/api/auth/callback/google   (NextAuth, browser origin)
#   https://api.yourdomain.com/api/sync/google/callback   (Calendar sync — API origin)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Public URL of the Next.js app (exact origin, no trailing slash).
NEXTAUTH_URL=http://localhost:3000
# Comma-separated Gmail addresses allowed to sign in.
ALLOWED_EMAILS=you@gmail.com

# If the browser loads the UI on one host (e.g. planner.example.com) but calls the API on
# another (e.g. api.example.com), set a shared parent domain so the session cookie is sent:
# NEXTAUTH_COOKIE_DOMAIN=.example.com
# Requires HTTPS in production. Leave unset when web + API are same-site (e.g. reverse proxy).

# Per-user requests per minute for /api/ai/* (rolling 60s window in Redis).
AI_RATE_LIMIT_RPM=20

# -----------------------------------------------------------------------------
# Google Calendar — optional OAuth + sync (see README checklist)
# -----------------------------------------------------------------------------
# Must match an authorized redirect URI in Google Cloud (Web client).
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/sync/google/callback

# Worker: periodic Google pull (ms). 0 = disabled.
GOOGLE_CALENDAR_PULL_INTERVAL_MS=0

# -----------------------------------------------------------------------------
# Docker Compose — Postgres password (must match DATABASE_URL on the host)
# -----------------------------------------------------------------------------
# DB_PASSWORD=devplanner

# Optional host port overrides (compose): POSTGRES_PORT, REDIS_PORT, RADICALE_PORT, API_PORT, WEB_PORT

# API Docker entrypoint: set to 1 to skip drizzle-kit push (use versioned SQL migrations in CI instead).
# SKIP_SCHEMA_SYNC=0

# For `docker compose up -d --build`, Next.js bakes this into the web image.
# Use the API URL **browsers** will use (e.g. http://YOUR_IP:3001 or https://api.example.com).
NEXT_PUBLIC_API_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Not used by the codebase today (reserved / future)
# -----------------------------------------------------------------------------
# Better Auth, Anthropic, etc. are not wired in this repo yet.
# BETTER_AUTH_SECRET=
# AI_PROVIDER=openai
# ANTHROPIC_API_KEY=
